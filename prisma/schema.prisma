// Узгоджено з DB_script.MD (PostgreSQL)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  STATION_ADMIN
  USER

  @@map("user_role")
}

enum StationStatus {
  WORK
  ARCHIVED
  NOT_WORKING
  FIX

  @@map("station_status")
}

enum PortStatus {
  FREE
  USED
  REPAIRED
  NOT_WORKING

  @@map("port_status")
}

enum TariffPeriod {
  DAY
  NIGHT

  @@map("tariff_period")
}

enum BookingStatus {
  BOOKED
  /** Слот минув або бронювання без дії — у БД один статус `MISSED`. */
  MISSED
  CANCELLED
  COMPLETED

  @@map("booking_status")
}

enum BookingType {
  CALC
  DEPOSIT

  @@map("booking_type")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FAILED

  @@map("session_status")
}

enum PaymentMethod {
  CARD
  APPLE_PAY
  GOOGLE_PAY

  @@map("payment_method")
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED

  @@map("payment_status")
}

model EvUser {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(50)
  surname      String   @db.VarChar(50)
  email        String   @unique @db.VarChar(254)
  phoneNumber  String   @map("phone_number") @db.VarChar(15)
  passwordHash String   @map("password_hash") @db.VarChar(254)
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")

  vehicles Vehicle[]
  bookings Booking[]
  sessions Session[]

  @@map("ev_user")
}

model Location {
  id           Int                    @id @default(autoincrement())
  coordinates  Unsupported("point")
  country      String                 @db.VarChar(100)
  city         String                 @db.VarChar(100)
  street       String                 @db.VarChar(100)
  houseNumber  String                 @map("house_number") @db.VarChar(10)
  stations     Station[]

  @@map("location")
}

model Station {
  id         Int           @id @default(autoincrement())
  locationId Int           @map("location_id")
  name       String        @db.VarChar(100)
  status     StationStatus @default(WORK)
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at")

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  ports    Port[]

  @@map("station")
}

model ConnectorType {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(64)
  ports Port[]

  @@map("connector_type")
}

model Port {
  stationId       Int            @map("station_id")
  portNumber      Int            @map("port_number")
  maxPower        Decimal        @map("max_power") @db.Decimal(5, 2)
  connectorTypeId Int?           @map("connector_type_id")
  status          PortStatus     @default(FREE)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at")

  station       Station        @relation(fields: [stationId], references: [id], onDelete: Cascade)
  connectorType ConnectorType? @relation(fields: [connectorTypeId], references: [id])
  bookings      Booking[]
  sessions      Session[]

  @@id([stationId, portNumber])
  @@map("port")
}

model Vehicle {
  id              Int      @id @default(autoincrement())
  userId          Int      @map("user_id")
  licensePlate    String   @unique @map("license_plate") @db.VarChar(20)
  brand           String   @db.VarChar(50)
  vehicleModel    String   @map("model") @db.VarChar(50)
  batteryCapacity Decimal  @map("battery_capacity") @db.Decimal(5, 2)

  user     EvUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]
  sessions Session[]

  @@map("vehicle")
}

model Tariff {
  id            Int          @id @default(autoincrement())
  tariffType    TariffPeriod @map("tariff_type")
  pricePerKwh   Decimal      @map("price_per_kwh") @db.Decimal(10, 2)
  effectiveDate DateTime     @default(now()) @map("effective_date") @db.Date
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @default(now()) @updatedAt @map("updated_at")

  @@unique([tariffType, effectiveDate])
  @@map("tariff")
}

model TariffPrediction {
  id             Int          @id @default(autoincrement())
  targetDate     DateTime     @map("target_date") @db.Date
  tariffType     TariffPeriod @map("tariff_type")
  predictedPrice Decimal      @map("predicted_price") @db.Decimal(10, 2)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([targetDate, tariffType])
  @@map("tariff_prediction")
}

model Booking {
  id               Int           @id @default(autoincrement())
  userId           Int?          @map("user_id")
  vehicleId        Int?          @map("vehicle_id")
  stationId        Int           @map("station_id")
  portNumber       Int           @map("port_number")
  startTime        DateTime      @map("start_time")
  endTime          DateTime      @map("end_time")
  status           BookingStatus @default(BOOKED)
  bookingType      BookingType   @default(CALC) @map("booking_type")
  prepaymentAmount Decimal       @default(0) @map("prepayment_amount") @db.Decimal(10, 2)
  createdAt        DateTime      @default(now()) @map("created_at")

  user     EvUser?  @relation(fields: [userId], references: [id])
  vehicle  Vehicle? @relation(fields: [vehicleId], references: [id])
  port     Port     @relation(fields: [stationId, portNumber], references: [stationId, portNumber])
  sessions Session[]

  @@map("booking")
}

model Session {
  id          Int           @id @default(autoincrement())
  userId      Int?          @map("user_id")
  vehicleId   Int?          @map("vehicle_id")
  stationId   Int           @map("station_id")
  portNumber  Int           @map("port_number")
  bookingId   Int?          @map("booking_id")
  startTime   DateTime      @default(now()) @map("start_time")
  endTime     DateTime?     @map("end_time")
  kwhConsumed Decimal       @default(0) @map("kwh_consumed") @db.Decimal(10, 3)
  status      SessionStatus @default(ACTIVE)

  user    EvUser?  @relation(fields: [userId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  port    Port     @relation(fields: [stationId, portNumber], references: [stationId, portNumber])
  booking Booking? @relation(fields: [bookingId], references: [id])
  bill    Bill?

  @@map("session")
}

model Bill {
  id                Int           @id @default(autoincrement())
  sessionId         Int           @unique @map("session_id")
  calculatedAmount  Decimal       @map("calculated_amount") @db.Decimal(10, 2)
  pricePerKwhAtTime Decimal?      @map("price_per_kwh_at_time") @db.Decimal(10, 2)
  /** Для PENDING може бути null — користувач обирає при оплаті. */
  paymentMethod     PaymentMethod? @map("payment_method")
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  paidAt            DateTime?     @map("paid_at")
  createdAt         DateTime      @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("bill")
}
