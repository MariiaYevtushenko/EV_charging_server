DATABASE_URL=
ALLOW_DEV_SEED=true

SEED_MASSIVE_USER_COUNT=1000
SEED_DEMO_BOOKINGS_COUNT=2000
# Максимальна глибина в минуле (календарних днів) для дат минулих бронювань у SeedBookings (1…1200, дефолт 120)
# SEED_DEMO_BOOKINGS_DAYS_BACK=120
# Цільова кількість сесій у SeedSessions; якщо не задано — збігається з SEED_DEMO_BOOKINGS_COUNT
# SEED_DEMO_SESSIONS_COUNT=2000
# Частка сесій із минулих бронювань (0…1), решта — walk-in без booking_id
# SEED_SESSION_FROM_BOOKING_SHARE=0.5

TARIFF_API_URL=
TARIFF_API_PER_DAY=
# Нормалізація грн/кВт·год після API (збої одиниці виміру / зайві нулі). false — лише округлення.
# TARIFF_SANITIZE=false
# TARIFF_UAH_PLAUSIBLE_MIN=2
# TARIFF_UAH_PLAUSIBLE_MAX=35
# TARIFF_SANITIZE_ASSUMED_EUR_RATE=45 — евристика зайвого множення на курс
# TARIFF_SANITIZE_LOG=true — лог підміни ціни
TARIFF_API_ENTSOE=
ENTSOE_IN_DOMAIN=10YPL-AREA-----S
ENTSOE_OUT_DOMAIN=10YPL-AREA-----S
ENTSOE_DOCUMENT_TYPE=A44

ENTSOE_CLAMP_NEGATIVE_PRICES=
# ENTSO-E: при сиді багатьох днів (TARIFF_SEED_DAYS) API дає HTTP 429 — пауза між днями (мс) і повтори
# ENTSOE_SEED_DELAY_MS=800
# ENTSOE_SEED_SEQUENTIAL=true — послідовний сид ENTSO-E (як раніше); інакше — паралельні запити
# ENTSOE_HTTP_MAX_RETRIES=10
# ENTSOE_429_BACKOFF_MS=3000

# Сид тарифів з API: скільки останніх календарних днів (1–1200). Броні/сесії в db/Seed_demo_bookings_sessions_bills.sql — у межах останніх 120 днів у минуле.
TARIFF_SEED_DAYS=1200
# Паралельність HTTP при сиді ENTSO-E та TARIFF_API_PER_DAY (деф. 6; макс. 32)
# TARIFF_SEED_FETCH_CONCURRENCY=6
# Після успішного збору цін — JSON у server/scripts/seed/data/tariff_seed_snapshot.json (резерв без API)
# TARIFF_SEED_WRITE_SNAPSHOT=false
# Якщо файл снапшота валідний для TARIFF_SEED_DAYS / anchor — пропустити мережу
# TARIFF_SEED_USE_SNAPSHOT_FIRST=true
# TARIFF_SEED_SNAPSHOT_PATH=scripts/seed/data/tariff_seed_snapshot.json


ENTSOE_FETCH_DAYS=

TOKEN=

# Сума резерву за бронь (грн), якщо клієнт не передав prepaymentAmount (DEPOSIT)
DEPOSIT_AMOUNT_UAH=200

# Орієнтовна потужність зарядки (кВт) для CALC-передплати: min(тривалість×кВт, ємність АКБ)
CHARGE_KW_ASSUMED=7

# Макс. надбавка ₴/кВт·год до динамічного тарифу за 100% «заповненості» дня бронювання (7–22)
# STATION_LOAD_MAX_SURCHARGE_UAH_PER_KWH=2

# Прогноз тарифів (Python forecast/ai_engine.py → tariff_prediction: 21 день × DAY + NIGHT рядки)
# Без рядків у таблиці tariff прогноз не запускається (у лог: «неможливо сформувати прогноз…»). Після seed (кнопка / seed:all) — додаткова спроба.
# FORECAST_AUTO_RUN=false — повністю вимкнути
# FORECAST_RUN_ON_START=false — не запускати одразу після старту (лише за інтервалом)
# FORECAST_INTERVAL_HOURS=24 — щоденне оновлення (24 год); зменшіть для тестів
# FORECAST_START_DELAY_SEC=5 — затримка першого запуску після старту сервера
# PYTHON_PATH=python3
# FORECAST_HORIZON_DAYS=21 — скільки днів уперед записує ai_engine.py у tariff_prediction
