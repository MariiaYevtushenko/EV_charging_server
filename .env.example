DATABASE_URL=
ALLOW_DEV_SEED=true

# Повний сид (npm run seed:all → scripts/seed-all-data.ts): користувачі й демо booking/session/bill
SEED_MASSIVE_USER_COUNT=1000
SEED_DEMO_BOOKINGS_COUNT=120

# JSON-API: один URL або ?date= при TARIFF_API_PER_DAY=true (ігнорується, якщо URL — ENTSO-E)
# ENTSO-E: базовий URL (наприклад https://web-api.tp.entsoe.eu/api) — XML A44, один запит/день без цього прапорця
TARIFF_API_URL=
TARIFF_API_PER_DAY=
TARIFF_API_ENTSOE=
ENTSOE_IN_DOMAIN=10YPL-AREA-----S
ENTSOE_OUT_DOMAIN=10YPL-AREA-----S
ENTSOE_DOCUMENT_TYPE=A44
# Від’ємні ціни A44 у тариф/консоль: за замовчуванням |x| (додатне). Сирі з API: false
ENTSOE_CLAMP_NEGATIVE_PRICES=
# Скільки календарних днів сидити tariff (DAY+NIGHT на день), типово 90
TARIFF_SEED_DAYS=90

# Скільки UTC-доб вивести в консоль (npm run entsoe:fetch), інакше = TARIFF_SEED_DAYS
ENTSOE_FETCH_DAYS=

TOKEN=
